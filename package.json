{
  "name": "tsu-energy",
  "version": "2.0.0",
  "description": "TSu Energy - Electrochemistry Modelling and Management Official Website",
  "main": "index.html",
  "scripts": {
    "dev": "tailwindcss -i ./src/tailwind.css -o ./assets/css/tailwind.css --watch",
    "build": "tailwindcss -i ./src/tailwind.css -o ./assets/css/tailwind.css --minify",
    "build:prod": "npm run build && npm run optimize",
    "optimize": "echo 'Build optimized for production'",
    "format": "prettier --write \"**/*.{html,js,css,json,md}\"",
    "format:check": "prettier --check \"**/*.{html,js,css,json,md}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/TSu-Energy/TSu-Energy.github.io.git"
  },
  "keywords": [
    "electrochemistry",
    "energy",
    "modelling",
    "management",
    "tailwindcss"
  ],
  "author": "TSu Energy Team",
  "license": "MIT",
  "devDependencies": {
    "prettier": "^2.6.2",
    "prettier-plugin-tailwindcss": "^0.1.9",
    "tailwindcss": "^3.0.15"
  }
}
